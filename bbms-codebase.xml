                        <td><small>{{ log.timestamp }}</small></td>
                        <td><span class="badge bg-{{ 'success' if log.action_type == 'INSERT' else 'primary' }}">{{ log.action_type }}</span></td>
                        <td><small>{{ log.table_name }}</small></td>
