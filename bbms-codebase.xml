                            {% if f.urgency_level == 'Critical' %}<span class="badge bg-danger">Critical</span>{% endif %}
                        </td>
                        <td>#{{ f.bag_id }}</td>
                        <td>{{ f.fl_allocated }} ml</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Audit Trail -->
    <div class="tab-pane fade" id="audit">
        <div class="card p-4 shadow-sm">
            <p class="text-muted small">Recent system-level actions (full log on <a href="{{ url_for('audit') }}">Audit Trail</a> page)</p>
            <table class="table table-sm table-striped">
                <thead>
                    <tr><th>Time</th><th>Action</th><th>Table</th><th>Record</th><th>Old</th><th>New</th><th>By</th></tr>
                </thead>
                <tbody>
                    {% for log in audit_log %}
