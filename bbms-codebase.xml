<file path="templates/donor.html">
{% extends 'base.html' %}

{% block content %}
<div class="row">
    <!-- Registration Form -->
    <div class="col-md-4">
        <div class="card p-4 mb-4">
            <h4>Register New Donor</h4>
            <form method="POST">
                <input type="hidden" name="register" value="true">
                <div class="mb-3">
                    <label>Full Name</label>
                    <input type="text" name="name" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label>Blood Group</label>
                    <select name="blood_group" class="form-select" required>
                        <option value="A+">A+</option>
                        <option value="A-">A-</option>
                        <option value="B+">B+</option>
                        <option value="B-">B-</option>
                        <option value="AB+">AB+</option>
                        <option value="AB-">AB-</option>
                        <option value="O+">O+</option>
                        <option value="O-">O-</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label>Phone</label>
                    <input type="text" name="phone" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-brand w-100">Register Donor</button>
            </form>
        </div>
    </div>

    <!-- Donation Log -->
    <div class="col-md-8">
        <div class="card p-4 mb-4">
            <h4>Log Donation</h4>
            <form method="POST" class="row g-3">
                <input type="hidden" name="donate" value="true">
                <div class="col-md-5">
                    <label>Select Donor</label>
                    <select name="donor_id" class="form-select" required>
                        {% for donor in donors %}
                        <option value="{{ donor.donor_id }}">{{ donor.name }} ({{ donor.blood_group }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label>Quantity (ml)</label>
                    <input type="number" name="quantity" class="form-control" value="450" required>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="split_components" id="splitCheck">
                        <label class="form-check-label small" for="splitCheck">Split into<br>components</label>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Save</button>
                </div>
            </form>
            <small class="text-muted mt-2 d-block">
                Splitting creates separate RBC (200ml/42d), Platelets (50ml/5d), and Plasma (200ml/365d) bags.
                The 56-day donation safety interval is enforced by a database trigger.
            </small>
        </div>

        <!-- Donor Loyalty Leaderboard (Item 9) -->
        <div class="card p-4">
            <h5 class="mb-3"><i class="bi bi-trophy me-1"></i> Donor Loyalty &amp; Eligibility</h5>
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Group</th>
                        <th>Donations</th>
                        <th>Total Vol</th>
                        <th>Score</th>
                        <th>Eligible?</th>
                        <th>Last Donation</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for d in donor_scores %}
                    <tr>
                        <td>{{ d.donor_id }}</td>
                        <td>{{ d.name }}</td>
                        <td>
                            <span class="badge bg-{{ 'danger' if d.blood_group in ['O-','AB-'] else 'secondary' }}">
                                {{ d.blood_group }}
                            </span>
                            {% if d.rare_bonus > 0 %}
                            <small class="text-danger"><i class="bi bi-star-fill"></i> rare</small>
                            {% endif %}
                        </td>
                        <td>{{ d.total_donations }}</td>
                        <td>{{ d.total_volume_ml }} ml</td>
                        <td>
                            <span class="badge bg-primary">{{ d.total_donations * 10 + d.rare_bonus }}</span>
                        </td>
                        <td>
                            {% if d.is_eligible %}
                            <span class="badge bg-success"><i class="bi bi-check-lg"></i> Eligible</span>
                            {% else %}
                            <span class="badge bg-warning text-dark">Wait 56d</span>
                            {% endif %}
                        </td>
                        <td>{{ d.last_donation_date or 'Never' }}</td>
                        <td>
                            <form method="POST" style="display:inline">
                                <input type="hidden" name="deactivate" value="true">
                                <input type="hidden" name="donor_id" value="{{ d.donor_id }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Soft-delete this donor?')">
                                    Deactivate
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="templates/home.html">
{% extends 'base.html' %}

{% block content %}
<!-- 1. Critical Alerts Section -->
{% if alerts %}
<div class="row mb-4">
    <div class="col-12">
        <div class="alert alert-danger shadow-sm d-flex justify-content-between align-items-center">
            <div>
                <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> CRITICAL SHORTAGES
                    DETECTED</h4>
                <ul class="mb-0">
                    {% for alert in alerts %}
                    <li><strong>{{ alert.requested_group }}</strong> needed urgently: {{ alert.total_needed }} ml</li>
                    {% endfor %}
                </ul>
            </div>
            <form action="{{ url_for('allocate_all') }}" method="POST">
                <button type="submit" class="btn btn-dark btn-lg fw-bold pulse-button">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> ALLOCATE RESOURCES NOW
                </button>
            </form>
        </div>
    </div>
</div>
{% else %}
<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h1 class="display-5 fw-bold text-dark">Blood Bank Dashboard</h1>
        <p class="lead text-muted">Real-time inventory, allocation & predictive analytics</p>
    </div>
    <div class="col-md-4 text-end">
        <form action="{{ url_for('allocate_all') }}" method="POST">
            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                Run Allocation Algorithm
            </button>
        </form>
    </div>
</div>
{% endif %}

<!-- Predictive Shortage Alerts (Item 7) -->
{% if shortage_alerts %}
<div class="row mb-4">
    <div class="col-12">
        <div class="alert alert-warning shadow-sm">
            <h5 class="fw-bold"><i class="bi bi-graph-down-arrow me-1"></i> Predictive Shortage Forecast</h5>
            <p class="mb-2 small text-muted">Based on average daily consumption over the past 30 days</p>
            <div class="row">
                {% for sa in shortage_alerts %}
                <div class="col-md-3 mb-2">
                    <div class="card border-warning">
                        <div class="card-body py-2 text-center">
                            <h4 class="fw-bold text-danger">{{ sa.blood_group }}</h4>
                            <p class="mb-0"><strong>{{ sa.projected_days }}</strong> days supply left</p>
                            <small class="text-muted">{{ sa.current_ml }} ml @ {{ sa.daily_rate }} ml/day</small>
                            {% if shortage_donors.get(sa.blood_group) %}
                            <hr class="my-1">
                            <small class="text-success fw-bold">Top donors to contact:</small><br>
                            {% for donor in shortage_donors[sa.blood_group] %}
                            <small>{{ donor.name }} ({{ donor.phone or 'N/A' }})</small><br>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- Expiring Soon Warning -->
{% if expiring_soon %}
<div class="row mb-4">
    <div class="col-12">
        <div class="alert alert-info shadow-sm">
            <h5 class="fw-bold"><i class="bi bi-clock-history me-1"></i> Bags Expiring Within 5 Days</h5>
            <div class="table-responsive">
                <table class="table table-sm table-borderless mb-0">
                    <thead><tr><th>Bag</th><th>Group</th><th>Component</th><th>Volume</th><th>Expires</th><th>Days Left</th></tr></thead>
                    <tbody>
                    {% for bag in expiring_soon %}
                    <tr>
                        <td>#{{ bag.bag_id }}</td>
                        <td><span class="badge bg-secondary">{{ bag.blood_group }}</span></td>
                        <td>{{ bag.component_type }}</td>
                        <td>{{ bag.current_volume_ml }} ml</td>
                        <td>{{ bag.expiry_date }}</td>
                        <td><span class="badge bg-{{ 'danger' if bag.days_until_expiry <= 2 else 'warning' }}">{{ bag.days_until_expiry }}d</span></td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- 2. Stock Ticker (Summary) -->
<div class="row g-4 mb-5">
    {% for item in inventory %}
    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-{{ 'danger' if item.total_vol < 1000 else 'success' }}">
            <div class="card-body text-center">
                <h2 class="display-4 fw-bold">{{ item.blood_group }}</h2>
                <p class="fs-5 mb-0">{{ item.total_vol }} <small class="text-muted">ml</small></p>
                <p class="text-muted small">{{ item.bag_count }} Bags</p>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12 text-center">
        <div class="alert alert-warning">No blood bags in stock!</div>
    </div>
    {% endfor %}
</div>

<!-- 3. Detailed Views (Tabs) -->
<ul class="nav nav-tabs mb-4" id="myTab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory"
            type="button">Detailed Inventory</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="component-tab" data-bs-toggle="tab" data-bs-target="#component-view"
            type="button">By Component</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="kivixa-history-tab" data-bs-toggle="tab" data-bs-target="#history"
            type="button">Donation History</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="fulfilled-tab" data-bs-toggle="tab" data-bs-target="#fulfilled"
            type="button">Fulfilled Requests</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="audit-tab" data-bs-toggle="tab" data-bs-target="#audit"
