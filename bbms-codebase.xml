{% extends 'base.html' %}

{% block content %}
<div class="row g-4">
    <!-- Left Column: Forms -->
    <div class="col-md-4">
        <!-- Add Hospital Form -->
        <div class="card p-4 shadow-sm mb-4">
            <h5 class="fw-bold text-primary"><i class="bi bi-hospital me-1"></i> Add New Hospital</h5>
            <form method="POST">
                <input type="hidden" name="add_hospital" value="true">
                <div class="mb-2">
                    <label class="form-label small text-muted">Contact Person</label>
                    <input type="text" name="name" class="form-control form-control-sm" required
