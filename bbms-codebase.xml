        <div class="card p-4 shadow-sm">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Donor</th>
                        <th>Quantity</th>
                        <th>Log ID</th>
                    </tr>
                </thead>
                <tbody>
                    {% for d in donations %}
                    <tr>
                        <td>{{ d.donation_date }}</td>
                        <td>{{ d.name }}</td>
                        <td>{{ d.quantity_ml }} ml</td>
                        <td>#{{ d.donation_id }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Fulfilled Requests -->
    <div class="tab-pane fade" id="fulfilled">
        <div class="card p-4 shadow-sm">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Recipient</th>
                        <th>Request</th>
                        <th>Allocated From Bag</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    {% for f in fulfilled %}
